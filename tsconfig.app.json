{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client", "vite-plugin-pwa/client"]
  },
  "include": ["src"]
}
